<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#F5F5FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🃏 跑的快 辅助工具"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="正在检查权限..."
        android:textSize="14sp"
        android:textColor="#5555AA"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btn_start"
        android:layout_width="260dp"
        android:layout_height="56dp"
        android:text="▶ 启动辅助服务"
        android:textSize="18sp"
        android:background="#3366FF"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_stop"
        android:layout_width="260dp"
        android:layout_height="48dp"
        android:text="■ 停止服务"
        android:textSize="16sp"
        android:background="#FF4444"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_test"
        android:layout_width="260dp"
        android:layout_height="48dp"
        android:text="🧪 测试算牌逻辑"
        android:textSize="16sp"
        android:background="#33AA66"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="使用说明：\n1. 点击「启动」并允许悬浮窗权限\n2. 返回游戏，悬浮窗将显示建议\n3. 点击悬浮窗「分析」触发算牌\n\n当前版本：v1.0 本地版\n（无需联网，完全离线运行）"
        android:textSize="13sp"
        android:textColor="#888888"
        android:lineSpacingExtra="6dp"/>

</LinearLayout>
